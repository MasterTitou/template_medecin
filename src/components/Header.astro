---
import CalBooking from './CalBooking.astro';

const navItems = [
  { name: 'Accueil', href: '/' },
  { name: 'À propos', href: '/about' },
  { name: 'Services', href: '/services' },
  { name: 'Rendez-vous', href: '/reservation' },
  { name: 'Téléconsultation', href: '/teleconsultation' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 w-full bg-white/70 backdrop-blur-md border-b border-slate-200 dark:bg-slate-900/70 dark:border-slate-800">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center gap-2">
        <a href="/" class="flex items-center space-x-2 group">
          <div class="w-10 h-10 bg-gradient-to-br from-medical-blue to-medical-blue-dark rounded-lg flex items-center justify-center text-white font-bold text-xl transition-transform group-hover:scale-110">
            L
          </div>
          <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-medical-blue to-medical-blue-dark">
            Dr. Liégeois
          </span>
        </a>
      </div>
      
      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-slate-600 hover:text-medical-blue transition-colors dark:text-slate-300 dark:hover:text-medical-blue-dark"
          >
            {item.name}
          </a>
        ))}
        <div class="flex items-center gap-4 border-l pl-4 border-slate-200 dark:border-slate-800">
          <slot name="theme-toggle" />
          <CalBooking 
            text="Prendre RDV" 
            variant="primary" 
            class="!text-sm !py-2 !px-4 shadow-sm hover:shadow-md"
          />
        </div>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center gap-1">
        <slot name="theme-toggle" />
        <button 
          type="button" 
          class="w-12 h-12 flex items-center justify-center text-slate-600 hover:text-medical-blue focus:outline-none dark:text-slate-300 dark:hover:text-medical-blue-dark transition-colors z-[70]" 
          id="mobile-menu-button"
          aria-expanded="false"
        >
          <span class="sr-only">Ouvrir le menu</span>
          <div class="relative w-6 h-5">
            <span class="absolute block w-6 h-0.5 bg-current transition-all duration-300 ease-in-out top-0" id="burger-top"></span>
            <span class="absolute block w-6 h-0.5 bg-current transition-all duration-300 ease-in-out top-1/2 -translate-y-1/2" id="burger-mid"></span>
            <span class="absolute block w-6 h-0.5 bg-current transition-all duration-300 ease-in-out bottom-0" id="burger-bot"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Fullscreen mobile menu overlay -->
  <div 
    class="fixed inset-0 z-[60] bg-white dark:bg-slate-900 translate-x-full transition-transform duration-500 ease-in-out md:hidden flex flex-col pt-24 px-8" 
    id="mobile-menu"
  >
    <div class="flex flex-col space-y-6">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-3xl font-extrabold text-slate-900 transition-colors hover:text-medical-blue dark:text-white dark:hover:text-medical-blue-light"
        >
          {item.name}
        </a>
      ))}
    </div>
    
    <div class="mt-auto pb-44 space-y-8">
       <div class="space-y-4">
          <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">Contact Direct</p>
          <a href="tel:+3241234567" class="flex items-center gap-4 text-xl font-bold text-medical-blue group">
             <div class="w-12 h-12 bg-medical-blue/10 rounded-full flex items-center justify-center group-active:scale-95 transition-transform">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
             </div>
             +32 4 123 45 67
          </a>
       </div>
       <CalBooking 
          text="Prendre RDV maintenant" 
          variant="primary" 
          class="w-full h-16 !text-xl !rounded-2xl shadow-xl flex items-center justify-center font-bold"
       />
    </div>
  </div>
</header>

<script>
  const setupMenu = () => {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const bTop = document.getElementById('burger-top');
    const bMid = document.getElementById('burger-mid');
    const bBot = document.getElementById('burger-bot');
    let open = false;

    if (!button || !menu || !bTop || !bMid || !bBot) return;

    const toggleMenu = () => {
      open = !open;
      button.setAttribute('aria-expanded', open.toString());
      
      if (open) {
        menu.classList.remove('translate-x-full');
        bTop.classList.add('rotate-45', 'translate-y-[9px]');
        bMid.classList.add('opacity-0');
        bBot.classList.add('-rotate-45', '-translate-y-[9px]');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.add('translate-x-full');
        bTop.classList.remove('rotate-45', 'translate-y-[9px]');
        bMid.classList.remove('opacity-0');
        bBot.classList.remove('-rotate-45', '-translate-y-[9px]');
        document.body.style.overflow = '';
      }
    };

    button.addEventListener('click', toggleMenu);
    
    // Close menu on link click
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        if (open) toggleMenu();
      });
    });
  };

  // Support for Astro View Transitions
  document.addEventListener('astro:page-load', setupMenu);
  setupMenu();
</script>
