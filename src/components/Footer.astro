---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 py-12 border-t border-slate-800">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center space-x-2 mb-4">
          <div class="w-8 h-8 bg-gradient-to-br from-medical-blue to-medical-blue-dark rounded flex items-center justify-center text-white font-bold">
            L
          </div>
          <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-medical-blue to-medical-blue-dark">
            Dr. Liégeois
          </span>
        </div>
        <p class="max-w-md text-slate-400 mb-6">
          Votre santé est notre priorité. Une approche bienveillante et moderne de la médecine générale en plein cœur de Liège.
        </p>
        <div class="flex space-x-4">
          <!-- Social Icons (Placeholders) -->
          <a href="#" class="hover:text-medical-blue transition-colors">
            <span class="sr-only">Facebook</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="#" class="hover:text-medical-blue-dark transition-colors">
            <span class="sr-only">LinkedIn</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.238 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        </div>
      </div>
      
      <div>
        <h3 class="text-white font-semibold mb-4">Navigation</h3>
        <ul class="space-y-2">
          <li><a href="/" class="hover:text-medical-blue transition-colors">Accueil</a></li>
          <li><a href="/about" class="hover:text-medical-blue transition-colors">À propos</a></li>
          <li><a href="/services" class="hover:text-medical-blue transition-colors">Services</a></li>
          <li><a href="/reservation" class="hover:text-medical-blue transition-colors">Rendez-vous</a></li>
          <li><a href="/contact" class="hover:text-medical-blue transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-2">
          <li class="flex items-start">
            <svg class="h-5 w-5 mr-2 text-medical-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Rue du Palais de Justice, 4000 Liège</span>
          </li>
          <li class="flex items-center">
            <svg class="h-5 w-5 mr-2 text-medical-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span>+32 4 123 45 67</span>
          </li>
          <li class="flex items-center">
            <svg class="h-5 w-5 mr-2 text-medical-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span>contact@dr-liegeois.be</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-slate-800 text-center text-sm text-slate-500">
      <p>&copy; {currentYear} Dr. Liégeois. Tous droits réservés. Dédié au bien-être des Liégeois.</p>
    </div>
  </div>
</footer>
