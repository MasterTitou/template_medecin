---
interface Props {
  username?: string;
  calLink?: string;
  slug?: string;
  text?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  class?: string;
}

const { 
  username = import.meta.env.PUBLIC_CAL_USERNAME || "votre-slug-cal", 
  calLink = "",
  slug = "consultation",
  text = "Prendre RDV",
  variant = "primary",
  class: className = ""
} = Astro.props;

const fullLink = calLink || (slug ? `${username}/${slug}` : username);

const variants = {
  primary: "bg-medical-blue text-white hover:bg-medical-blue/90 shadow-md hover:shadow-lg",
  secondary: "bg-medical-blue-light text-medical-blue hover:bg-blue-100 dark:bg-slate-800 dark:text-blue-400 dark:hover:bg-slate-700",
  outline: "bg-transparent border-2 border-medical-blue text-medical-blue hover:bg-medical-blue hover:text-white",
  ghost: "bg-transparent text-slate-600 hover:text-medical-blue dark:text-slate-400 dark:hover:text-blue-400"
};

const baseStyles = "inline-flex items-center justify-center px-6 py-3 rounded-xl font-bold transition-all duration-300 transform active:scale-95 cursor-pointer";
const variantStyles = variants[variant];
---

<button
  data-cal-link={fullLink}
  data-cal-config='{"layout":"month_view"}'
  class:list={[baseStyles, variantStyles, className]}
>
  <slot>
    {text}
  </slot>
</button>
