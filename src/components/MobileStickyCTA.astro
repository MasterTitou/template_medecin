---
import CalBooking from './CalBooking.astro';
---

<div class="fixed bottom-0 left-0 right-0 z-[100] p-4 bg-white/80 backdrop-blur-lg border-t border-slate-200 dark:bg-slate-900/80 dark:border-slate-800 md:hidden flex justify-center items-center shadow-[0_-8px_32px_-12px_rgba(0,0,0,0.1)] transition-transform duration-300" id="sticky-cta">
  <CalBooking 
    text="Prendre RDV" 
    variant="primary" 
    class="w-full h-12 !rounded-xl shadow-lg font-bold text-lg active:scale-95 transition-all" 
  />
</div>

<style>
  #sticky-cta {
    padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
  }
  
  /* Hide on scroll down, show on scroll up for better UX */
  :global(.scroll-down) #sticky-cta {
    transform: translateY(100%);
  }
  
  :global(.scroll-up) #sticky-cta {
    transform: translateY(0);
  }
</style>
