---
interface Props {
  title: string;
  description: string;
  icon?: string;
  class?: string;
}

const { title, description, icon, class: className } = Astro.props;
---

<div class:list={["bg-glass dark:bg-slate-900/40 p-6 shadow-xl hover:shadow-2xl transition-all hover:-translate-y-1 group", className]}>
  {icon && (
    <div class="w-12 h-12 mb-4 rounded-full bg-belgian-teal/10 flex items-center justify-center text-belgian-teal group-hover:bg-belgian-teal group-hover:text-white transition-colors">
      <slot name="icon" />
    </div>
  )}
  <h3 class="text-xl font-semibold mb-2 text-slate-900 dark:text-white group-hover:text-belgian-teal transition-colors">
    {title}
  </h3>
  <p class="text-slate-600 dark:text-slate-400">
    {description}
  </p>
</div>
