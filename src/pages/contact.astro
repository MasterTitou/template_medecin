---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
	<section class="py-20 bg-slate-50 dark:bg-slate-950">
		<div class="container mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h1 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-6">Contactez-nous</h1>
				<p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
					Le cabinet est situé au centre de Liège. N'hésitez pas à nous contacter pour toute question ou pour prendre rendez-vous.
				</p>
			</div>
			
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
				<!-- Contact Info & Form -->
				<div class="space-y-8">
					<div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-800">
						<h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Informations de contact</h2>
						<ul class="space-y-6">
							<li class="flex items-start">
								<div class="w-12 h-12 bg-belgian-teal/10 rounded-xl flex items-center justify-center text-belgian-teal mr-4 flex-shrink-0">
									<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
								</div>
								<div>
									<h3 class="font-bold text-slate-900 dark:text-white">Adresse</h3>
									<p class="text-slate-600 dark:text-slate-400">Rue du Palais de Justice, 4000 Liège, Belgique</p>
								</div>
							</li>
							<li class="flex items-start">
								<div class="w-12 h-12 bg-belgian-teal/10 rounded-xl flex items-center justify-center text-belgian-teal mr-4 flex-shrink-0">
									<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
								</div>
								<div>
									<h3 class="font-bold text-slate-900 dark:text-white">Téléphone</h3>
									<p class="text-slate-600 dark:text-slate-400">+32 4 123 45 67</p>
								</div>
							</li>
							<li class="flex items-start">
								<div class="w-12 h-12 bg-belgian-teal/10 rounded-xl flex items-center justify-center text-belgian-teal mr-4 flex-shrink-0">
									<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
								</div>
								<div>
									<h3 class="font-bold text-slate-900 dark:text-white">E-mail</h3>
									<p class="text-slate-600 dark:text-slate-400">contact@dr-liegeois.be</p>
								</div>
							</li>
						</ul>
					</div>
					
					<div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-800">
						<h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Horaires du secrétariat</h2>
						<div class="space-y-2 text-slate-600 dark:text-slate-400">
							<div class="flex justify-between"><span>Lundi - Vendredi</span> <span>08h00 - 18h00</span></div>
							<div class="flex justify-between"><span>Samedi</span> <span>09h00 - 12h00</span></div>
							<div class="flex justify-between text-liege-orange font-semibold"><span>Dimanche</span> <span>Fermé</span></div>
						</div>
					</div>
				</div>
				
				<!-- Map -->
				<div class="h-[500px] lg:h-auto rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-800">
					<iframe 
						width="100%" 
						height="100%" 
						frameborder="0" 
						scrolling="no" 
						marginheight="0" 
						marginwidth="0" 
						src="https://www.openstreetmap.org/export/embed.html?bbox=5.5600%2C50.6300%2C5.5800%2C50.6500&amp;layer=mapnik&amp;marker=50.6400%2C5.5700" 
						style="border: 0"
					></iframe>
				</div>
			</div>
		</div>
	</section>
</Layout>
