---
import Layout from '../layouts/Layout.astro';
const username = import.meta.env.PUBLIC_CAL_USERNAME || "votre-slug-cal";
---

<Layout title="Réservez votre consultation" description="Prenez rendez-vous en ligne avec le Dr. Liégeois via notre plateforme sécurisée.">
  <section class="py-12 md:py-20 lg:py-24 bg-slate-50 dark:bg-slate-950 relative overflow-hidden">
    <!-- Decorations -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-[500px] h-[500px] bg-medical-blue/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-medical-blue/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="container mx-auto px-4 relative z-10">
      <nav class="flex mb-8 items-center text-sm font-medium text-slate-500 dark:text-slate-400 gap-2">
        <a href="/" class="hover:text-medical-blue transition-colors">Accueil</a>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-slate-900 dark:text-white">Réservation</span>
      </nav>

      <div class="max-w-4xl mx-auto text-center mb-12">
        <span class="inline-block px-4 py-1.5 mb-6 text-sm font-bold tracking-wider text-medical-blue uppercase bg-medical-blue-light rounded-full dark:bg-blue-900/30 dark:text-blue-400">
          Disponibilités en temps réel
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white mb-6">
          Prendre <span class="text-medical-blue">Rendez-vous</span>
        </h1>
        <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10">
          Veuillez sélectionner le type de service pour afficher les disponibilités correspondantes.
        </p>

        <!-- Service Selector Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto mb-12">
          <button 
            id="btn-consultation"
            class="flex flex-col items-center p-6 bg-white dark:bg-slate-900 rounded-2xl border-2 border-medical-blue shadow-lg hover:shadow-xl transition-all group md:scale-105"
            data-slug="consultation"
          >
            <div class="w-14 h-14 bg-medical-blue-light dark:bg-blue-900/30 rounded-full flex items-center justify-center text-medical-blue mb-4 transition-transform group-hover:scale-110">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Consultation</h3>
            <p class="text-sm text-slate-500 mt-2">Suivi médical classique</p>
          </button>

          <button 
            id="btn-prisedesang"
            class="flex flex-col items-center p-6 bg-white dark:bg-slate-900 rounded-2xl border-2 border-transparent shadow-md hover:shadow-lg transition-all group hover:border-medical-blue/30"
            data-slug="prise-de-sang"
          >
            <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center text-slate-600 dark:text-slate-400 mb-4 transition-transform group-hover:scale-110 group-hover:bg-medical-blue-light group-hover:text-medical-blue">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.183.394l-1.158.907a.5.5 0 00.196.884l1.658.261a2 2 0 011.512 1.512l.261 1.658a.5.5 0 00.884.196l.907-1.158a2 2 0 01.394-1.183l.158-.318a2 2 0 00.517-3.86l-.158-.318a2 2 0 00-3.86.517l-.318.158a2 2 0 00-1.183.394l-1.158.907a.5.5 0 00.196.884" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Prise de sang</h3>
            <p class="text-sm text-slate-500 mt-2">Analyses de laboratoire</p>
          </button>
        </div>
      </div>

      <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl overflow-hidden border border-slate-200 dark:border-slate-800 min-h-[500px] sm:min-h-[700px] md:min-h-[800px] relative">
        <div id="loading-spinner" class="absolute inset-0 flex items-center justify-center bg-white dark:bg-slate-900 z-10 transition-opacity duration-500">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 border-4 border-medical-blue/20 border-t-medical-blue rounded-full animate-spin"></div>
            <p class="mt-4 text-slate-500 animate-pulse">Chargement du calendrier...</p>
          </div>
        </div>

        <!-- Cal inline embed code -->
        <div 
            class="w-full h-[600px] sm:h-[700px] md:h-[800px] overflow-auto opacity-0 transition-opacity duration-700" 
            id="my-cal-inline"
        ></div>
        
        <script is:inline define:vars={{ username }}>
          let currentSlug = "consultation";
          
          const initCal = (slug = currentSlug) => {
            if (!username || username === "votre-slug-cal" || username === "undefined") {
              console.error("Cal.com: Username is missing.");
              return;
            }

            const loader = document.getElementById('loading-spinner');
            const calElement = document.getElementById('my-cal-inline');
            
            // Show loader during transition
            if (loader) {
              loader.classList.remove('opacity-0', 'pointer-events-none');
              loader.style.display = 'flex';
            }
            if (calElement) calElement.classList.add('opacity-0');

            if (typeof Cal !== 'undefined') {
              try {
                // Clear previous build
                calElement.innerHTML = ""; 

                Cal("inline", {
                  elementOrSelector: "#my-cal-inline",
                  calLink: `${username}/${slug}`,
                  layout: "month_view",
                  config: {
                     theme: document.documentElement.classList.contains('dark') ? 'dark' : 'light'
                  }
                });
                
                setTimeout(() => {
                  if (calElement) calElement.classList.remove('opacity-0');
                  if (loader) {
                    loader.classList.add('opacity-0', 'pointer-events-none');
                  }
                }, 800);
              } catch (e) {
                console.error("Cal.com initialization failed:", e);
              }
            } else {
              setTimeout(() => initCal(slug), 100);
            }
          };

          const setupButtons = () => {
            const btnConsult = document.getElementById('btn-consultation');
            const btnBlood = document.getElementById('btn-prisedesang');

            const setActive = (activeBtn, inactiveBtn) => {
              activeBtn.classList.add('border-medical-blue', 'shadow-lg', 'md:scale-105');
              activeBtn.classList.remove('border-transparent', 'shadow-md');
              activeBtn.querySelector('div').classList.add('bg-medical-blue-light', 'text-medical-blue');
              activeBtn.querySelector('div').classList.remove('bg-slate-100', 'text-slate-600');
              
              inactiveBtn.classList.remove('border-medical-blue', 'shadow-lg', 'md:scale-105');
              inactiveBtn.classList.add('border-transparent', 'shadow-md');
              inactiveBtn.querySelector('div').classList.remove('bg-medical-blue-light', 'text-medical-blue');
              inactiveBtn.querySelector('div').classList.add('bg-slate-100', 'text-slate-600');
            };

            btnConsult?.addEventListener('click', () => {
              if (currentSlug !== "consultation") {
                currentSlug = "consultation";
                setActive(btnConsult, btnBlood);
                initCal("consultation");
              }
            });

            btnBlood?.addEventListener('click', () => {
              if (currentSlug !== "prise-de-sang") {
                currentSlug = "prise-de-sang";
                setActive(btnBlood, btnConsult);
                initCal("prise-de-sang");
              }
            });
          };

          // Support for both standard load and Astro View Transitions
          const startup = () => {
            setupButtons();
            initCal();
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', startup);
          } else {
            startup();
          }
          
          document.addEventListener('astro:page-load', startup);
        </script>
      </div>
      
      <div class="mt-12 sm:mt-16 bg-medical-blue-light dark:bg-blue-900/10 rounded-2xl p-6 sm:p-8 border border-medical-blue/10 flex flex-col md:flex-row items-center justify-between gap-6 max-w-4xl mx-auto text-center md:text-left">
        <div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Besoin d'aide ?</h3>
          <p class="text-slate-600 dark:text-slate-400">Si vous ne trouvez pas de créneau qui vous convient, contactez notre secrétariat.</p>
        </div>
        <a href="tel:+3241234567" class="w-full md:w-auto inline-flex justify-center items-center gap-2 px-6 py-4 md:py-3 bg-white dark:bg-slate-800 text-medical-blue font-bold rounded-xl shadow-sm hover:shadow-md transition-all active:scale-95">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +32 4 123 45 67
        </a>
      </div>
    </div>
  </section>
</Layout>
