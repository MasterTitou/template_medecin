---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import CalBooking from '../components/CalBooking.astro';
---

<Layout title="Accueil">
	<section class="relative py-20 overflow-hidden bg-slate-50 dark:bg-slate-950">
		<div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="flex flex-col lg:flex-row items-center gap-12">
				<div class="flex-1 text-center lg:text-left">
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight mb-6">
						Votre santé, <br />
						<span class="text-medical-blue">notre engagement</span> à Liège.
					</h1>
					<p class="text-lg text-slate-600 dark:text-slate-400 mb-8 max-w-2xl mx-auto lg:mx-0">
						Le Dr. Liégeois vous accueille dans son cabinet moderne pour des soins personnalisés et de qualité. Médecine générale, prévention et suivi pour toute la famille.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
						<CalBooking text="Prendre RDV (Popup)" />
						<a href="/reservation" class="px-8 py-4 bg-white border border-slate-200 text-slate-700 font-bold rounded-lg shadow-sm hover:bg-slate-50 transition-all dark:bg-slate-800 dark:border-slate-700 dark:text-white dark:hover:bg-slate-700 inline-flex items-center justify-center">
							Page de Réservation
						</a>
					</div>
				</div>
				<div class="flex-1 relative">
					<div class="absolute -top-10 -left-10 w-40 h-40 bg-medical-blue-dark/10 rounded-full blur-3xl animate-pulse"></div>
					<div class="absolute -bottom-10 -right-10 w-40 h-40 bg-medical-blue/10 rounded-full blur-3xl animate-pulse"></div>
					<div class="relative rounded-2xl overflow-hidden shadow-2xl border-4 border-white dark:border-slate-800 transform rotate-2 hover:rotate-0 transition-transform duration-500">
						<img 
							src="/hero-doctor.png" 
							alt="Dr. Liégeois dans son cabinet à Liège" 
							class="w-full h-auto object-cover aspect-[4/3]"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 bg-white dark:bg-slate-900">
		<div class="container mx-auto px-4">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Pourquoi nous choisir ?</h2>
				<div class="w-20 h-1 bg-medical-blue-dark mx-auto"></div>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<Card 
					title="Expertise Médicale" 
					description="Plus de 15 ans d'expérience au service de la communauté liégeoise."
					icon="shield"
				>
					<svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
					</svg>
				</Card>
				
				<Card 
					title="Cabinet Moderne" 
					description="Équipements de pointe et cadre accueillant pour votre confort."
					icon="office"
				>
					<svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
					</svg>
				</Card>
				
				<Card 
					title="Disponibilité" 
					description="Prise de rendez-vous facile en ligne et secrétariat réactif."
					icon="calendar"
				>
					<svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
					</svg>
				</Card>
			</div>
		</div>
	</section>
</Layout>
