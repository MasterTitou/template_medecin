---
import Layout from '../layouts/Layout.astro';
import CalBooking from '../components/CalBooking.astro';
---

<Layout title="Téléconsultation" description="Découvrez notre interface de téléconsultation sécurisée. Prête pour l'intégration de vos outils de visio-conférence préférés.">
  <section class="py-20 bg-slate-50 dark:bg-slate-950 overflow-hidden relative">
     <!-- Design elements -->
     <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-gradient-to-b from-medical-blue/5 to-transparent pointer-events-none"></div>
     
     <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-16 pt-10">
           <div class="flex-1 text-center lg:text-left">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold tracking-wider text-medical-blue uppercase bg-medical-blue-light dark:bg-blue-900/30 dark:text-blue-400 mb-6">
                <span class="relative flex h-2 w-2 mr-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-medical-blue opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-medical-blue"></span>
                </span>
                Téléconsultation Ready
              </span>
              <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight mb-6">
                La médecine, <br />
                <span class="text-medical-blue">sans barrières.</span>
              </h1>
              <p class="text-xl text-slate-600 dark:text-slate-400 mb-10 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                Notre plateforme est optimisée pour intégrer vos outils de télétransmission et de visioconférence préférés. Offrez à vos patients une expérience fluide, sécurisée et professionnelle.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                 <CalBooking text="Tester la réservation" slug="visio" variant="primary" class="w-full sm:w-auto" />
                 <a href="/contact" class="w-full sm:w-auto px-8 py-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-white font-bold rounded-xl shadow-sm hover:bg-slate-50 transition-all active:scale-95 text-center">
                    Nous contacter
                 </a>
              </div>
           </div>
           <div class="flex-1 relative">
              <div class="absolute -inset-4 bg-medical-blue/20 rounded-[2.5rem] blur-2xl animate-pulse"></div>
              <div class="relative rounded-[2rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.3)] border-8 border-white dark:border-slate-800 lg:rotate-2">
                 <img src="/teleconsultation_hero.png" alt="Interface de téléconsultation" class="w-full h-auto object-cover aspect-video" />
                 <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end p-6 sm:p-8">
                    <div class="flex items-center gap-4 text-white">
                       <div class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center">
                          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M21 6.5l-4 4V7c0-.55-.45-1-1-1H5c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h11c.55 0 1-.45 1-1v-3.5l4 4v-11z"/></svg>
                       </div>
                       <div>
                          <p class="font-bold text-sm sm:text-base">Consultation en cours</p>
                          <p class="text-[10px] sm:text-xs text-white/70">Connexion sécurisée AES-256</p>
                       </div>
                    </div>
                 </div>
              </div>
           </div>
        </div>
     </div>
  </section>

  <section class="py-24 bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800">
     <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
           <div class="space-y-4">
              <div class="w-14 h-14 bg-medical-blue-light dark:bg-blue-900/30 rounded-2xl flex items-center justify-center text-medical-blue text-2xl">
                 <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Sécurité & Standards</h3>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-normal">Flux vidéo cryptés de bout en bout. Architecture compatible avec les hébergements certifiés HDS (France) et les normes de protection des données belges.</p>
           </div>
           <div class="space-y-4">
              <div class="w-14 h-14 bg-medical-blue-light dark:bg-blue-900/30 rounded-2xl flex items-center justify-center text-medical-blue text-2xl">
                 <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Installation Instantanée</h3>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-normal">Aucun logiciel à installer pour le patient. Une simple connexion via navigateur suffit pour démarrer la visio en un clic.</p>
           </div>
           <div class="space-y-4">
              <div class="w-14 h-14 bg-medical-blue-light dark:bg-blue-900/30 rounded-2xl flex items-center justify-center text-medical-blue text-2xl">
                 <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Intégration Native</h3>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-normal">Lien de visioconférence généré automatiquement (Jitsi, Cal Video) et synchronisé immédiatement avec vos calendriers.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Compatibility Showcase -->
  <section class="py-20 bg-slate-50 dark:bg-slate-950">
     <div class="container mx-auto px-4">
        <div class="text-center mb-16">
           <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Compatible avec vos outils habituels</h2>
           <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
              Nous intégrons les solutions leaders du marché pour s'adapter à votre flux de travail existant.
           </p>
        </div>
        
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 grayscale hover:grayscale-0 transition-all">
           <span class="text-2xl font-bold text-slate-400">Doctolib</span>
           <span class="text-2xl font-bold text-slate-400">Maiia</span>
           <span class="text-2xl font-bold text-slate-400">Hellocare</span>
           <span class="text-2xl font-bold text-slate-400">Qare</span>
           <span class="text-2xl font-bold text-slate-400">Consulib</span>
        </div>
     </div>
  </section>

  <section class="py-20">
     <div class="container mx-auto px-4">
        <div class="bg-gradient-to-br from-medical-blue to-medical-blue-dark rounded-[2.5rem] p-8 sm:p-12 lg:p-20 text-white text-center relative overflow-hidden shadow-2xl">
           <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
           <h2 class="text-3xl md:text-5xl font-extrabold mb-8 relative z-10">Prêt à moderniser votre cabinet ?</h2>
           <p class="text-xl text-white/80 mb-12 max-w-2xl mx-auto relative z-10 font-normal">
              Découvrez comment nos solutions technologiques peuvent transformer votre relation patient.
           </p>
           <div class="relative z-10 flex flex-col items-center gap-6">
              <CalBooking text="Demander une démo" slug="visio" variant="secondary" class="bg-white text-medical-blue hover:bg-slate-100 hover:text-medical-blue-dark w-full sm:w-auto" />
              
              <!-- Demo Notice -->
              <div class="flex items-center gap-2 text-white/60 text-xs sm:text-sm bg-black/10 px-4 py-2 rounded-full border border-white/10">
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                 <p>Note de démo : Visio standard (Jitsi/Cal) utilisée ici. Intégration HDS possible pour le projet final.</p>
              </div>
           </div>
        </div>
     </div>
  </section>
</Layout>
